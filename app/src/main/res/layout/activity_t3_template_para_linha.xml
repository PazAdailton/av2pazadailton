<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/t3_img_favo"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/radiobutton_off_background" />

    <TextView
        android:id="@+id/t3_tx_nome"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:text="t3_tx_nome"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/t3_tx_email"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-5dp"
        android:text="t3_tx_email"
        android:textSize="16sp"
        android:textStyle="italic"
        app:layout_constraintStart_toStartOf="@+id/t3_tx_nome"
        app:layout_constraintTop_toBottomOf="@+id/t3_tx_nome" />

    <TextView
        android:id="@+id/t3_tx_telef"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="t3_tx_telef"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="@+id/t3_tx_email"
        app:layout_constraintTop_toBottomOf="@+id/t3_tx_email" />

    <Space
        android:layout_width="wrap_content"
        android:layout_height="12dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="@+id/t3_tx_telef"
        app:layout_constraintTop_toBottomOf="@+id/t3_tx_telef" />



</androidx.constraintlayout.widget.ConstraintLayout>